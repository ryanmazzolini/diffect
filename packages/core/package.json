{
  "name": "@diffect/core",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "diffect": "./dist/cli.js",
    "diffectd": "./dist/daemon-bin.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev:daemon": "node --experimental-strip-types src/daemon-bin.ts"
  },
  "dependencies": {
    "@diffect/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
