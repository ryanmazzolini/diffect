{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Allow the desktop shell's loopback web UI to use native window chrome interactions.",
  "windows": ["main"],
  "remote": {
    "urls": ["http://127.0.0.1:*", "http://localhost:*"]
  },
  "permissions": [
    "core:window:default",
    "core:window:allow-start-dragging",
    "allow-open-website-review",
    "allow-position-website-review",
    "allow-close-website-review",
    "allow-report-website-pick"
  ]
}
