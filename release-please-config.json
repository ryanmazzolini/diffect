{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "bootstrap-sha": "6681fb5b92e24994aa4c23f38a87699bbe80159a",
  "release-type": "node",
  "include-v-in-tag": true,
  "include-component-in-tag": false,
  "draft": true,
  "force-tag-creation": true,
  "packages": {
    ".": {
      "extra-files": [
        {
          "type": "json",
          "path": "packages/desktop/src-tauri/tauri.conf.json",
          "jsonpath": "$.version"
        },
        {
          "type": "toml",
          "path": "packages/desktop/src-tauri/Cargo.toml",
          "jsonpath": "$.package.version"
        },
        {
          "type": "toml",
          "path": "packages/desktop/src-tauri/Cargo.lock",
          "jsonpath": "$.package[?(@.name.value==\"diffect-desktop\")].version"
        }
      ]
    }
  }
}
