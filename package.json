{
  "name": "diffect",
  "version": "0.2.1",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "check:release-version": "node scripts/check-release-version.mjs",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @diffect/e2e test",
    "typecheck": "pnpm -r typecheck",
    "dev": "pnpm --filter @diffect/web dev"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.1.9",
    "@types/node": "^22.10.0"
  }
}
