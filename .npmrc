# Supply-chain hardening.
#
# pnpm blocks dependency lifecycle (postinstall/build) scripts by default; the
# few packages that legitimately need one are allowlisted via
# `onlyBuiltDependencies` in pnpm-workspace.yaml.
#
# minimum-release-age refuses to install any package version published less than
# 3 days (4320 min) ago. Worm-style npm compromises are typically detected and
# yanked within hours, so a short cooldown blunts them without much friction.
minimum-release-age=4320
